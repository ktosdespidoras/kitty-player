#!/usr/bin/env bash
set -u

ESC=$'\033'
ALT_ON="${ESC}[?1049h"
ALT_OFF="${ESC}[?1049l"
CURSOR_OFF="${ESC}[?25l"
CURSOR_ON="${ESC}[?25h"
CLEAR="${ESC}[2J"
HOME="${ESC}[H"
EOL="${ESC}[K"

palette=(
  "38;2;255;94;148"
  "38;2;99;213;255"
  "38;2;126;255;178"
  "38;2;255;207;94"
  "38;2;191;134;255"
)

status=""
artist=""
title=""
album=""
length_us=0
position_s=0
player_name=""
has_playerctl=0
has_player=0
old_stty=""
last_cols=0
last_rows=0
force_refresh=1

command -v stty >/dev/null 2>&1 && old_stty="$(stty -g 2>/dev/null || true)"

cleanup() {
  [[ -n "$old_stty" ]] && stty "$old_stty" 2>/dev/null || true
  printf "%b%b%b" "$CURSOR_ON" "$ALT_OFF" "${ESC}[0m"
}

trap cleanup EXIT INT TERM

term_size() {
  cols=$(tput cols 2>/dev/null || printf 80)
  rows=$(tput lines 2>/dev/null || printf 24)
  (( cols < 40 )) && cols=40
  (( rows < 16 )) && rows=16
}

clear_on_resize() {
  if (( cols != last_cols || rows != last_rows )); then
    printf "%b" "$CLEAR"
    last_cols="$cols"
    last_rows="$rows"
  fi
}

trim_text() {
  local text="$1"
  local max="$2"

  if (( ${#text} > max )); then
    printf "%s..." "${text:0:max-3}"
  else
    printf "%s" "$text"
  fi
}

fmt_time() {
  local total="${1:-0}"

  total="${total%.*}"
  [[ "$total" =~ ^[0-9]+$ ]] || total=0
  printf "%02d:%02d" $((total / 60)) $((total % 60))
}

run_playerctl() {
  playerctl "$@" >/dev/null 2>&1 || true
}

refresh_player() {
  local meta pos raw_length

  has_playerctl=0
  has_player=0
  status=""
  artist=""
  title=""
  album=""
  length_us=0
  position_s=0
  player_name=""

  command -v playerctl >/dev/null 2>&1 || return
  has_playerctl=1

  status="$(playerctl status 2>/dev/null || true)"
  [[ -n "$status" ]] || return
  has_player=1

  player_name="$(playerctl -l 2>/dev/null | head -n 1 || true)"
  meta="$(playerctl metadata --format '{{artist}}|||{{title}}|||{{album}}|||{{mpris:length}}' 2>/dev/null || true)"

  artist="${meta%%|||*}"
  meta="${meta#*|||}"
  title="${meta%%|||*}"
  meta="${meta#*|||}"
  album="${meta%%|||*}"
  raw_length="${meta##*|||}"

  artist="${artist:-Unknown artist}"
  title="${title:-Unknown title}"
  album="${album:-}"
  [[ "$raw_length" =~ ^[0-9]+$ ]] && length_us="$raw_length" || length_us=0

  pos="$(playerctl position 2>/dev/null || true)"
  pos="${pos%.*}"
  [[ "$pos" =~ ^[0-9]+$ ]] && position_s="$pos" || position_s=0
}

bar_line() {
  local tick="$1"
  local width="$2"
  local out=""
  local blocks=("." ":" "-" "=" "+" "*" "#" "%" "#" "*" "+" "=")
  local i n

  for ((i = 0; i < width; i++)); do
    if [[ "$status" == "Paused" ]]; then
      n=$(( (i + tick / 4) % 4 ))
    else
      n=$(( (i * 7 + tick * 3 + (i % 5) * tick) % ${#blocks[@]} ))
    fi
    out+="${blocks[$n]}"
  done

  printf "%s" "$out"
}

center() {
  local text="$1"
  local width="$2"
  local len=${#text}
  local pad=$(( (width - len) / 2 ))

  (( pad < 0 )) && pad=0
  printf "%*s%s%b\n" "$pad" "" "$text" "$EOL"
}

blank_line() {
  printf "%b\n" "$EOL"
}

track_pulse() {
  local tick="$1"
  local width="$2"
  local out=""
  local i distance level char
  local center_pos=$(( tick % width ))

  for ((i = 0; i < width; i++)); do
    distance=$(( i - center_pos ))
    (( distance < 0 )) && distance=$(( -distance ))
    (( distance > width / 2 )) && distance=$(( width - distance ))
    level=$(( (distance + tick + i * 3) % 9 ))

    case "$level" in
      0|1) char="|" ;;
      2|3) char="/" ;;
      4|5) char="-" ;;
      6|7) char="\\" ;;
      *) char="." ;;
    esac

    if [[ "$status" == "Paused" ]]; then
      char="-"
    fi
    out+="$char"
  done

  printf "%s" "$out"
}

draw() {
  local tick="$1"
  local color="${palette[$(( tick % ${#palette[@]} ))]}"
  local duration_s=$(( length_us / 1000000 ))
  local width=$(( cols > 72 ? 44 : cols - 10 ))
  local filled=0
  local empty=$(( width - filled ))
  local spectrum_width=$(( cols > 86 ? 56 : cols - 8 ))
  local pulse_width=$(( cols > 88 ? 60 : cols - 8 ))

  (( width < 20 )) && width=20
  (( spectrum_width < 20 )) && spectrum_width=20
  (( pulse_width < 24 )) && pulse_width=24

  if (( duration_s > 0 )); then
    (( position_s > duration_s )) && position_s="$duration_s"
    filled=$(( position_s * width / duration_s ))
  else
    filled=$(( tick % width ))
  fi
  empty=$(( width - filled ))

  printf "%b" "$HOME"
  printf "%b" "${ESC}[${color}m"
  center "K I T T Y   P L A Y E R" "$cols"
  printf "%b" "${ESC}[0m"
  center "MPRIS terminal deck" "$cols"
  blank_line

  printf "%*s" $(( (cols - pulse_width) / 2 )) ""
  printf "%b%s%b%b\n" "${ESC}[${color}m" "$(track_pulse "$tick" "$pulse_width")" "${ESC}[0m" "$EOL"
  center "$(trim_text "$title" $((cols - 4)))" "$cols"
  printf "%*s" $(( (cols - pulse_width) / 2 )) ""
  printf "%b%s%b%b\n" "${ESC}[38;2;99;213;255m" "$(bar_line "$((tick + 9))" "$pulse_width")" "${ESC}[0m" "$EOL"

  blank_line
  center "$(trim_text "$artist - $title" $((cols - 4)))" "$cols"
  if [[ -n "$album" ]]; then
    center "$(trim_text "$album" $((cols - 4)))" "$cols"
  else
    center "" "$cols"
  fi
  center "status: $status${player_name:+ | player: $player_name}" "$cols"
  center "$(fmt_time "$position_s") / $(fmt_time "$duration_s")" "$cols"
  blank_line

  printf "%*s" $(( (cols - width - 2) / 2 )) ""
  printf "%b[" "${ESC}[38;2;90;90;100m"
  printf "%b%*s" "${ESC}[38;2;126;255;178m" "$filled" "" | tr ' ' '#'
  printf "%b%*s" "${ESC}[38;2;55;55;65m" "$empty" "" | tr ' ' '-'
  printf "%b]%b%b\n" "${ESC}[0m" "$EOL"

  blank_line
  printf "%*s" $(( (cols - spectrum_width) / 2 )) ""
  printf "%b%s%b%b\n" "${ESC}[38;2;99;213;255m" "$(bar_line "$tick" "$spectrum_width")" "${ESC}[0m" "$EOL"
  blank_line
  center "space play/pause | n next | p prev | s stop | r refresh | q quit" "$cols"
  printf "%b" "${ESC}[J"
}

draw_empty() {
  local color="${palette[$(( tick % ${#palette[@]} ))]}"

  printf "%b" "$HOME"
  printf "%b" "${ESC}[${color}m"
  center "K I T T Y   P L A Y E R" "$cols"
  printf "%b" "${ESC}[0m"
  blank_line
  blank_line

  if (( has_playerctl == 0 )); then
    center "playerctl is not installed" "$cols"
    center "install it, then run player again" "$cols"
    blank_line
    center "Arch: sudo pacman -S playerctl" "$cols"
    center "Debian/Ubuntu: sudo apt install playerctl" "$cols"
    center "Fedora: sudo dnf install playerctl" "$cols"
  else
    center "no active MPRIS player found" "$cols"
    center "open Spotify, mpv, VLC, Firefox, or another supported player" "$cols"
  fi

  blank_line
  blank_line
  center "q - quit | r - refresh" "$cols"
  printf "%b" "${ESC}[J"
}

handle_key() {
  case "$1" in
    q|Q) return 1 ;;
    " ") run_playerctl play-pause; force_refresh=1 ;;
    n|N) run_playerctl next; force_refresh=1 ;;
    p|P) run_playerctl previous; force_refresh=1 ;;
    s|S) run_playerctl stop; force_refresh=1 ;;
    r|R) force_refresh=1 ;;
  esac

  return 0
}

printf "%b%b%b" "$ALT_ON" "$CURSOR_OFF" "$CLEAR"
stty -echo -icanon time 0 min 0 2>/dev/null || true

tick=0
while true; do
  term_size
  clear_on_resize

  if (( force_refresh == 1 || tick % 8 == 0 )); then
    refresh_player
    force_refresh=0
  fi

  if (( has_player == 1 )); then
    draw "$tick"
  else
    draw_empty
  fi

  key=""
  IFS= read -r -s -n 1 -t 0.1 key 2>/dev/null || true
  handle_key "$key" || break

  tick=$((tick + 1))
done

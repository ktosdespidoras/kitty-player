#!/usr/bin/env bash

ESC=$'\033'
ALT_ON="${ESC}[?1049h"
ALT_OFF="${ESC}[?1049l"
CURSOR_OFF="${ESC}[?25l"
CURSOR_ON="${ESC}[?25h"
CLEAR="${ESC}[2J"
HOME="${ESC}[H"
EOL="${ESC}[K"

palette=(
  "38;2;255;94;148"
  "38;2;99;213;255"
  "38;2;126;255;178"
  "38;2;255;207;94"
  "38;2;191;134;255"
)

status=""
artist=""
title=""
album=""
length_us=0
position_s=0
position_cs=0
player_name=""
has_playerctl=0
has_player=0
old_stty=""
last_cols=0
last_rows=0
force_refresh=1
current_page=0
lyrics_key=""
lyrics_found=0
lyrics_synced=0
lyrics_path=""
lyrics_status=""
lyrics_lines=()
lyrics_times=()

load_env_file() {
  local file="$1"
  local line key value

  [[ -f "$file" ]] || return

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" == *"="* ]] || continue

    key="${line%%=*}"
    value="${line#*=}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"

    case "$key" in
      GENIUS_CLIENT_ID|GENIUS_CLIENT_SECRET|GENIUS_ACCESS_TOKEN)
        export "$key=$value"
        ;;
    esac
  done < "$file"
}

load_config() {
  local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"

  load_env_file "$config_home/kitty-player/env"
  load_env_file ".env"
  load_env_file ".env.local"
}

load_config

command -v stty >/dev/null 2>&1 && old_stty="$(stty -g 2>/dev/null || true)"

cleanup() {
  [[ -n "$old_stty" ]] && stty "$old_stty" 2>/dev/null || true
  printf "%b%b%b" "$CURSOR_ON" "$ALT_OFF" "${ESC}[0m"
}

trap cleanup EXIT INT TERM

term_size() {
  cols=$(tput cols 2>/dev/null || printf 80)
  rows=$(tput lines 2>/dev/null || printf 24)
  (( cols < 40 )) && cols=40
  (( rows < 16 )) && rows=16
}

clear_on_resize() {
  if (( cols != last_cols || rows != last_rows )); then
    printf "%b" "$CLEAR"
    last_cols="$cols"
    last_rows="$rows"
  fi
}

trim_text() {
  local text="$1"
  local max="$2"

  if (( ${#text} > max )); then
    printf "%s..." "${text:0:max-3}"
  else
    printf "%s" "$text"
  fi
}

slugify() {
  printf "%s" "$1" \
    | sed -E 's/[\/:*?"<>|#]+/-/g; s/[[:space:]]+/-/g; s/-+/-/g; s/^-//; s/-$//'
}

legacy_slugify() {
  printf "%s" "$1" \
    | tr "[:upper:]" "[:lower:]" \
    | tr -cd "[:alnum:] ._-" \
    | tr " " "-" \
    | tr -s "-"
}

current_lyrics_dir() {
  printf "%s" "${XDG_CACHE_HOME:-$HOME/.cache}/kitty-player/lyrics"
}

current_lyrics_base() {
  printf "%s-%s" "$(slugify "$artist")" "$(slugify "$title")"
}

fmt_time() {
  local total="${1:-0}"

  total="${total%.*}"
  [[ "$total" =~ ^[0-9]+$ ]] || total=0
  printf "%02d:%02d" $((total / 60)) $((total % 60))
}

seconds_to_cs() {
  local value="${1:-0}"
  local whole frac

  value="${value/,/.}"
  whole="${value%%.*}"
  frac=""
  [[ "$value" == *.* ]] && frac="${value#*.}"
  frac="${frac}00"
  frac="${frac:0:2}"

  [[ "$whole" =~ ^[0-9]+$ ]] || whole=0
  [[ "$frac" =~ ^[0-9]+$ ]] || frac=0
  printf "%s" $((10#$whole * 100 + 10#$frac))
}

lrc_time_to_cs() {
  local minutes="${1:-0}"
  local seconds="${2:-0}"
  local fraction="${3:-}"

  fraction="${fraction#.}"
  fraction="${fraction}00"
  fraction="${fraction:0:2}"

  [[ "$minutes" =~ ^[0-9]+$ ]] || minutes=0
  [[ "$seconds" =~ ^[0-9]+$ ]] || seconds=0
  [[ "$fraction" =~ ^[0-9]+$ ]] || fraction=0
  printf "%s" $((10#$minutes * 6000 + 10#$seconds * 100 + 10#$fraction))
}

run_playerctl() {
  run_with_timeout 1 playerctl "$@" >/dev/null 2>&1 || true
}

run_with_timeout() {
  local seconds="$1"
  shift

  if command -v timeout >/dev/null 2>&1; then
    timeout "$seconds" "$@"
  else
    "$@"
  fi
}

refresh_position() {
  local pos

  command -v playerctl >/dev/null 2>&1 || return
  pos="$(run_with_timeout 0.4 playerctl position 2>/dev/null || true)"
  [[ -n "$pos" ]] || return
  position_cs="$(seconds_to_cs "$pos")"
  position_s=$(( position_cs / 100 ))
}

refresh_player() {
  local meta raw_length

  has_playerctl=0
  has_player=0
  status=""
  artist=""
  title=""
  album=""
  length_us=0
  position_s=0
  position_cs=0
  player_name=""

  command -v playerctl >/dev/null 2>&1 || return
  has_playerctl=1

  status="$(run_with_timeout 0.6 playerctl status 2>/dev/null || true)"
  [[ -n "$status" ]] || return
  has_player=1

  player_name="$(run_with_timeout 0.6 playerctl -l 2>/dev/null | sed -n '1p' || true)"
  meta="$(run_with_timeout 0.8 playerctl metadata --format '{{artist}}|||{{title}}|||{{album}}|||{{mpris:length}}' 2>/dev/null || true)"

  artist="${meta%%|||*}"
  meta="${meta#*|||}"
  title="${meta%%|||*}"
  meta="${meta#*|||}"
  album="${meta%%|||*}"
  raw_length="${meta##*|||}"

  artist="${artist:-Unknown artist}"
  title="${title:-Unknown title}"
  album="${album:-}"
  [[ "$raw_length" =~ ^[0-9]+$ ]] && length_us="$raw_length" || length_us=0

  refresh_position
}

read_lyrics_file() {
  local line text minutes seconds

  lyrics_found=0
  lyrics_synced=0
  lyrics_lines=()
  lyrics_times=()

  [[ -n "$lyrics_path" && -f "$lyrics_path" ]] || return

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^\[([0-9]+):([0-9]+)(\.[0-9]+)?\](.*)$ ]]; then
      minutes="${BASH_REMATCH[1]}"
      seconds="${BASH_REMATCH[2]}"
      text="${BASH_REMATCH[4]}"
      lyrics_times+=( "$(lrc_time_to_cs "$minutes" "$seconds" "${BASH_REMATCH[3]}")" )
      lyrics_lines+=( "$text" )
      lyrics_synced=1
    elif [[ -n "$line" && ! "$line" =~ ^\[.*\]$ ]]; then
      lyrics_times+=( -1 )
      lyrics_lines+=( "$line" )
    fi
  done < "$lyrics_path"

  (( ${#lyrics_lines[@]} > 0 )) && lyrics_found=1
}

fetch_lrclib_lyrics() {
  local dir artist_slug title_slug duration_s response best lyrics synced target score

  command -v curl >/dev/null 2>&1 || { lyrics_status="install curl+jq for auto lyrics"; return; }
  command -v jq >/dev/null 2>&1 || { lyrics_status="install jq for auto lyrics"; return; }
  [[ "$artist" != "Unknown artist" && "$title" != "Unknown title" ]] || return

  dir="$(current_lyrics_dir)"
  mkdir -p "$dir" 2>/dev/null || true
  artist_slug="$(slugify "$artist")"
  title_slug="$(slugify "$title")"
  duration_s=$(( length_us / 1000000 ))

  response="$(
    curl -fsS --get "https://lrclib.net/api/search" \
      --connect-timeout 1 \
      --max-time 2 \
      --data-urlencode "artist_name=$artist" \
      --data-urlencode "track_name=$title" \
      --data-urlencode "album_name=$album" \
      2>/dev/null || true
  )"

  if [[ -n "$response" ]]; then
    best="$(
      printf "%s" "$response" | jq -c \
        --arg artist "$artist" \
        --arg title "$title" \
        --argjson duration "$duration_s" '
        def norm:
          ascii_downcase
          | gsub("\\([^)]*\\)|\\[[^]]*\\]"; " ")
          | gsub("\\b(feat|ft|with|prod)\\.?\\b.*$"; " ")
          | gsub("\\b(remaster(ed)?|live|explicit|clean|radio edit|single version|album version|official video)\\b"; " ")
          | gsub("[^[:alnum:]]+"; " ")
          | gsub("^ +| +$"; "");
        def compact: norm | gsub(" "; "");
        def rawcompact: gsub("\\([^)]*\\)|\\[[^]]*\\]"; " ") | gsub("[^[:alnum:]]+"; "");
        def diff(a; b): if a > b then a - b else b - a end;
        ($artist | norm) as $artist_norm |
        ($artist | compact) as $artist_compact |
        ($artist | rawcompact) as $artist_rawcompact |
        ($title | norm) as $title_norm |
        ($title | compact) as $title_compact |
        ($title | rawcompact) as $title_rawcompact |
        map(select((.syncedLyrics // .plainLyrics // "") != ""))
        | map(. + {
            matchScore:
              (
                ((.trackName // "") | norm) as $candidate_title |
                ((.trackName // "") | compact) as $candidate_title_compact |
                ((.trackName // "") | rawcompact) as $candidate_title_rawcompact |
                ((.artistName // "") | norm) as $candidate_artist |
                ((.artistName // "") | compact) as $candidate_artist_compact |
                ((.artistName // "") | rawcompact) as $candidate_artist_rawcompact |
                (if $candidate_title == $title_norm then 60
                 elif ($candidate_title | contains($title_norm)) or ($title_norm | contains($candidate_title)) then 45
                 elif ($candidate_title_compact | contains($title_compact)) or ($title_compact | contains($candidate_title_compact)) then 35
                 elif ($candidate_title_rawcompact | contains($title_rawcompact)) or ($title_rawcompact | contains($candidate_title_rawcompact)) then 35
                 else 0 end)
                +
                (if $candidate_artist == $artist_norm then 30
                 elif ($candidate_artist | contains($artist_norm)) or ($artist_norm | contains($candidate_artist)) then 20
                 elif ($candidate_artist_compact | contains($artist_compact)) or ($artist_compact | contains($candidate_artist_compact)) then 15
                 elif ($candidate_artist_rawcompact | contains($artist_rawcompact)) or ($artist_rawcompact | contains($candidate_artist_rawcompact)) then 15
                 else 0 end)
                +
                (if $duration > 0 and (.duration != null) then
                   (diff((.duration | tonumber); $duration) as $d |
                    if $d <= 2 then 20
                    elif $d <= 5 then 10
                    elif $d > 15 then -45
                    else 0 end)
                 else 0 end)
              )
          })
        | sort_by(.matchScore)
        | reverse
        | .[0] // empty
        | select(.matchScore >= 75)
        ' 2>/dev/null || true
    )"
  fi

  if [[ -z "$best" ]]; then
    response="$(
      curl -fsS --get "https://lrclib.net/api/search" \
        --connect-timeout 1 \
        --max-time 2 \
        --data-urlencode "q=$artist $title" \
        2>/dev/null || true
    )"
  fi

  if [[ -n "$response" && -z "$best" ]]; then
    best="$(
      printf "%s" "$response" | jq -c \
      --arg artist "$artist" \
      --arg title "$title" \
      --argjson duration "$duration_s" '
      def norm:
        ascii_downcase
        | gsub("\\([^)]*\\)|\\[[^]]*\\]"; " ")
        | gsub("\\b(feat|ft|with|prod)\\.?\\b.*$"; " ")
        | gsub("\\b(remaster(ed)?|live|explicit|clean|radio edit|single version|album version|official video)\\b"; " ")
        | gsub("[^[:alnum:]]+"; " ")
        | gsub("^ +| +$"; "");
      def compact: norm | gsub(" "; "");
      def rawcompact: gsub("\\([^)]*\\)|\\[[^]]*\\]"; " ") | gsub("[^[:alnum:]]+"; "");
      def diff(a; b): if a > b then a - b else b - a end;
      ($artist | norm) as $artist_norm |
      ($artist | compact) as $artist_compact |
      ($artist | rawcompact) as $artist_rawcompact |
      ($title | norm) as $title_norm |
      ($title | compact) as $title_compact |
      ($title | rawcompact) as $title_rawcompact |
      map(select((.syncedLyrics // .plainLyrics // "") != ""))
      | map(. + {
          matchScore:
            (
              ((.trackName // "") | norm) as $candidate_title |
              ((.trackName // "") | compact) as $candidate_title_compact |
              ((.trackName // "") | rawcompact) as $candidate_title_rawcompact |
              ((.artistName // "") | norm) as $candidate_artist |
              ((.artistName // "") | compact) as $candidate_artist_compact |
              ((.artistName // "") | rawcompact) as $candidate_artist_rawcompact |
              (if $candidate_title == $title_norm then 60
               elif ($candidate_title | contains($title_norm)) or ($title_norm | contains($candidate_title)) then 45
               elif ($candidate_title_compact | contains($title_compact)) or ($title_compact | contains($candidate_title_compact)) then 35
               elif ($candidate_title_rawcompact | contains($title_rawcompact)) or ($title_rawcompact | contains($candidate_title_rawcompact)) then 35
               else 0 end)
              +
              (if $candidate_artist == $artist_norm then 30
               elif ($candidate_artist | contains($artist_norm)) or ($artist_norm | contains($candidate_artist)) then 20
               elif ($candidate_artist_compact | contains($artist_compact)) or ($artist_compact | contains($candidate_artist_compact)) then 15
               elif ($candidate_artist_rawcompact | contains($artist_rawcompact)) or ($artist_rawcompact | contains($candidate_artist_rawcompact)) then 15
               else 0 end)
              +
              (if $duration > 0 and (.duration != null) then
                 (diff((.duration | tonumber); $duration) as $d |
                  if $d <= 2 then 20
                  elif $d <= 5 then 10
                  elif $d > 15 then -45
                  else 0 end)
               else 0 end)
            )
        })
      | sort_by(.matchScore)
      | reverse
      | .[0] // empty
      | select(.matchScore >= 75)
      ' 2>/dev/null || true
    )"
  fi

  if [[ -z "$best" ]]; then
    response="$(
      curl -fsS --get "https://lrclib.net/api/get" \
        --connect-timeout 1 \
        --max-time 2 \
        --data-urlencode "artist_name=$artist" \
        --data-urlencode "track_name=$title" \
        --data-urlencode "album_name=$album" \
        --data-urlencode "duration=$duration_s" \
        2>/dev/null || true
    )"
    if [[ -n "$response" ]]; then
      best="$(printf "%s" "$response" | jq -c 'select((.syncedLyrics // .plainLyrics // "") != "") | . + {matchScore: 70}' 2>/dev/null || true)"
    fi
  fi

  [[ -n "$best" ]] || { lyrics_status="lyrics match too weak"; return; }
  score="$(printf "%s" "$best" | jq -r '.matchScore // 0' 2>/dev/null || printf 0)"
  synced="$(printf "%s" "$best" | jq -r '.syncedLyrics // empty' 2>/dev/null || true)"
  lyrics="$(printf "%s" "$best" | jq -r '.plainLyrics // empty' 2>/dev/null || true)"

  if [[ -n "$synced" && "$synced" != "null" ]]; then
    target="$dir/$artist_slug-$title_slug.lrc"
    printf "%s\n" "$synced" > "$target"
  elif [[ -n "$lyrics" && "$lyrics" != "null" ]]; then
    target="$dir/$artist_slug-$title_slug.txt"
    printf "%s\n" "$lyrics" > "$target"
  else
    lyrics_status="lyrics not found online"
    return
  fi

  lyrics_path="$target"
  lyrics_status="downloaded lyrics score $score"
  read_lyrics_file
}

refetch_lyrics() {
  local dir base legacy_base

  dir="$(current_lyrics_dir)"
  base="$(current_lyrics_base)"
  legacy_base="$(legacy_slugify "$artist")-$(legacy_slugify "$title")"
  rm -f "$dir/$base.lrc" "$dir/$base.txt" 2>/dev/null || true
  rm -f "$dir/$legacy_base.lrc" "$dir/$legacy_base.txt" 2>/dev/null || true
  lyrics_key=""
  lyrics_path=""
  lyrics_found=0
  lyrics_status="refetching lyrics"
  load_lyrics
}

load_lyrics() {
  local key dir artist_slug title_slug legacy_artist_slug legacy_title_slug candidate

  key="$artist|||$title"
  [[ "$key" == "$lyrics_key" ]] && return
  lyrics_key="$key"
  lyrics_found=0
  lyrics_synced=0
  lyrics_path=""
  lyrics_status=""
  lyrics_lines=()
  lyrics_times=()

  dir="$(current_lyrics_dir)"
  artist_slug="$(slugify "$artist")"
  title_slug="$(slugify "$title")"
  legacy_artist_slug="$(legacy_slugify "$artist")"
  legacy_title_slug="$(legacy_slugify "$title")"

  for candidate in \
    "$dir/$artist_slug-$title_slug.lrc" \
    "$dir/$artist_slug-$title_slug.txt" \
    "$dir/$title_slug.lrc" \
    "$dir/$title_slug.txt" \
    "$dir/$legacy_artist_slug-$legacy_title_slug.lrc" \
    "$dir/$legacy_artist_slug-$legacy_title_slug.txt" \
    "$dir/$legacy_title_slug.lrc" \
    "$dir/$legacy_title_slug.txt"; do
    if [[ -f "$candidate" ]]; then
      lyrics_path="$candidate"
      read_lyrics_file
      return
    fi
  done

  fetch_lrclib_lyrics
}

bar_line() {
  local tick="$1"
  local width="$2"
  local out=""
  local blocks=("." ":" "-" "=" "+" "*" "#" "%" "#" "*" "+" "=")
  local i n

  for ((i = 0; i < width; i++)); do
    if [[ "$status" == "Paused" ]]; then
      n=$(( (i + tick / 4) % 4 ))
    else
      n=$(( (i * 7 + tick * 3 + (i % 5) * tick) % ${#blocks[@]} ))
    fi
    out+="${blocks[$n]}"
  done

  printf "%s" "$out"
}

center() {
  local text="$1"
  local width="$2"
  local len=${#text}
  local pad=$(( (width - len) / 2 ))

  (( pad < 0 )) && pad=0
  printf "%*s%s%b\n" "$pad" "" "$text" "$EOL"
}

blank_line() {
  printf "%b\n" "$EOL"
}

draw_tabs() {
  local active="$1"
  local one="[1 now playing]"
  local two="[2 lyrics]"
  local gap="   "
  local total=$(( ${#one} + ${#two} + ${#gap} ))
  local pad=$(( (cols - total) / 2 ))

  (( pad < 0 )) && pad=0
  printf "%*s" "$pad" ""
  if (( active == 0 )); then
    printf "%b%s%b%s%b%s%b%b\n" "${ESC}[38;2;255;207;94m" "$one" "${ESC}[0m" "$gap" "${ESC}[38;2;90;90;100m" "$two" "${ESC}[0m" "$EOL"
  else
    printf "%b%s%b%s%b%s%b%b\n" "${ESC}[38;2;90;90;100m" "$one" "${ESC}[0m" "$gap" "${ESC}[38;2;255;207;94m" "$two" "${ESC}[0m" "$EOL"
  fi
}

draw_progress() {
  local width="$1"
  local duration_cs=$(( length_us / 10000 ))
  local filled=0
  local empty

  (( width < 20 )) && width=20

  if (( duration_cs > 0 )); then
    (( position_cs > duration_cs )) && position_cs="$duration_cs"
    position_s=$(( position_cs / 100 ))
    filled=$(( position_cs * width / duration_cs ))
  else
    filled=$(( tick % width ))
  fi
  empty=$(( width - filled ))

  printf "%*s" $(( (cols - width - 2) / 2 )) ""
  printf "%b[" "${ESC}[38;2;90;90;100m"
  printf "%b%*s" "${ESC}[38;2;126;255;178m" "$filled" "" | tr ' ' '#'
  printf "%b%*s" "${ESC}[38;2;55;55;65m" "$empty" "" | tr ' ' '-'
  printf "%b]%b%b\n" "${ESC}[0m" "$EOL"
}

lyrics_index() {
  local count="${#lyrics_lines[@]}"
  local duration_cs=$(( length_us / 10000 ))
  local i current=0

  (( count == 0 )) && { printf "0"; return; }

  if (( lyrics_synced == 1 )); then
    for ((i = 0; i < count; i++)); do
      if (( lyrics_times[$i] <= position_cs )); then
        current="$i"
      else
        break
      fi
    done
  elif (( duration_cs > 0 )); then
    current=$(( position_cs * count / duration_cs ))
    (( current >= count )) && current=$(( count - 1 ))
    (( current < 0 )) && current=0
  else
    current=$(( (tick / 24) % count ))
  fi

  printf "%s" "$current"
}

panel_line() {
  local text="$1"
  local width="$2"
  local color="$3"
  local content_width=$(( width - 4 ))
  local shown

  shown="$(trim_text "$text" "$content_width")"
  printf "%*s" $(( (cols - width) / 2 )) ""
  printf "%b| %-${content_width}s |%b%b\n" "$color" "$shown" "${ESC}[0m" "$EOL"
}

draw_lyrics_panel() {
  local width="$1"
  local current prev next source_label

  (( width > cols - 4 )) && width=$(( cols - 4 ))
  (( width < 36 )) && width=36
  current="$(lyrics_index)"
  prev=$(( current - 1 ))
  next=$(( current + 1 ))

  printf "%*s" $(( (cols - width) / 2 )) ""
  printf "%b.%*s.%b%b\n" "${ESC}[38;2;90;90;100m" $(( width - 2 )) "" "${ESC}[0m" "$EOL" | tr ' ' '-'

  if (( lyrics_found == 1 )); then
    source_label="lyrics: ${lyrics_path##*/}"
    panel_line "$source_label" "$width" "${ESC}[38;2;90;90;100m"
    panel_line "" "$width" "${ESC}[38;2;90;90;100m"
    (( prev >= 0 )) && panel_line "${lyrics_lines[$prev]:-}" "$width" "${ESC}[38;2;99;213;255m" || panel_line "" "$width" "${ESC}[38;2;99;213;255m"
    panel_line "${lyrics_lines[$current]:-}" "$width" "${ESC}[38;2;255;207;94m"
    (( next < ${#lyrics_lines[@]} )) && panel_line "${lyrics_lines[$next]:-}" "$width" "${ESC}[38;2;126;255;178m" || panel_line "" "$width" "${ESC}[38;2;126;255;178m"
  else
    panel_line "${lyrics_status:-no lyrics file found}" "$width" "${ESC}[38;2;255;207;94m"
    panel_line "" "$width" "${ESC}[38;2;90;90;100m"
    panel_line "auto fetch uses LRCLIB, or put .lrc/.txt here:" "$width" "${ESC}[38;2;99;213;255m"
    panel_line "~/.cache/kitty-player/lyrics/" "$width" "${ESC}[38;2;126;255;178m"
    panel_line "$(slugify "$artist")-$(slugify "$title").lrc" "$width" "${ESC}[38;2;126;255;178m"
  fi

  printf "%*s" $(( (cols - width) / 2 )) ""
  printf "%b'%*s'%b%b\n" "${ESC}[38;2;90;90;100m" $(( width - 2 )) "" "${ESC}[0m" "$EOL" | tr ' ' '-'
}

draw_now_playing() {
  local tick="$1"
  local color="${palette[$(( tick % ${#palette[@]} ))]}"
  local duration_s=$(( length_us / 1000000 ))
  local width=$(( cols > 72 ? 44 : cols - 10 ))
  local spectrum_width=$(( cols > 86 ? 56 : cols - 8 ))

  (( width < 20 )) && width=20
  (( spectrum_width < 20 )) && spectrum_width=20

  printf "%b" "$HOME"
  printf "%b" "${ESC}[${color}m"
  center "K I T T Y   P L A Y E R" "$cols"
  printf "%b" "${ESC}[0m"
  center "MPRIS terminal deck" "$cols"
  draw_tabs 0
  blank_line

  center "$(trim_text "$title" $((cols - 4)))" "$cols"
  center "$(trim_text "$artist - $title" $((cols - 4)))" "$cols"
  if [[ -n "$album" ]]; then
    center "$(trim_text "$album" $((cols - 4)))" "$cols"
  else
    center "" "$cols"
  fi
  center "status: $status${player_name:+ | player: $player_name}" "$cols"
  center "$(fmt_time "$position_s") / $(fmt_time "$duration_s")" "$cols"
  blank_line

  draw_progress "$width"

  blank_line
  printf "%*s" $(( (cols - spectrum_width) / 2 )) ""
  printf "%b%s%b%b\n" "${ESC}[38;2;99;213;255m" "$(bar_line "$tick" "$spectrum_width")" "${ESC}[0m" "$EOL"
  blank_line
  center "tab switch | space play/pause | n next | p prev | s stop | r refresh | q quit" "$cols"
  printf "%b" "${ESC}[J"
}

draw_lyrics() {
  local tick="$1"
  local color="${palette[$(( tick % ${#palette[@]} ))]}"
  local duration_s=$(( length_us / 1000000 ))
  local width=$(( cols > 72 ? 44 : cols - 10 ))
  local lyrics_width=$(( cols > 92 ? 72 : cols - 8 ))

  (( width < 20 )) && width=20
  (( lyrics_width < 36 )) && lyrics_width=36

  printf "%b" "$HOME"
  printf "%b" "${ESC}[${color}m"
  center "K I T T Y   P L A Y E R" "$cols"
  printf "%b" "${ESC}[0m"
  center "MPRIS terminal deck" "$cols"
  draw_tabs 1
  blank_line

  load_lyrics
  draw_lyrics_panel "$lyrics_width"
  blank_line
  center "$(trim_text "$artist - $title" $((cols - 4)))" "$cols"
  center "$(fmt_time "$position_s") / $(fmt_time "$duration_s")" "$cols"
  blank_line
  draw_progress "$width"
  blank_line
  center "tab switch | L refetch lyrics | space play/pause | q quit" "$cols"
  printf "%b" "${ESC}[J"
}

draw() {
  if (( current_page == 0 )); then
    draw_now_playing "$1"
  else
    draw_lyrics "$1"
  fi
}

draw_empty() {
  local color="${palette[$(( tick % ${#palette[@]} ))]}"

  printf "%b" "$HOME"
  printf "%b" "${ESC}[${color}m"
  center "K I T T Y   P L A Y E R" "$cols"
  printf "%b" "${ESC}[0m"
  blank_line
  blank_line

  if (( has_playerctl == 0 )); then
    center "playerctl is not installed" "$cols"
    center "install it, then run player again" "$cols"
    blank_line
    center "Arch: sudo pacman -S playerctl" "$cols"
    center "Debian/Ubuntu: sudo apt install playerctl" "$cols"
    center "Fedora: sudo dnf install playerctl" "$cols"
  else
    center "no active MPRIS player found" "$cols"
    center "open Spotify, mpv, VLC, Firefox, or another supported player" "$cols"
  fi

  blank_line
  blank_line
  center "q - quit | r - refresh" "$cols"
  printf "%b" "${ESC}[J"
}

handle_key() {
  case "$1" in
    q|Q) return 1 ;;
    $'\t') current_page=$(( 1 - current_page )) ;;
    1) current_page=0 ;;
    2) current_page=1 ;;
    " ") run_playerctl play-pause; force_refresh=1 ;;
    n|N) run_playerctl next; force_refresh=1 ;;
    p|P) run_playerctl previous; force_refresh=1 ;;
    s|S) run_playerctl stop; force_refresh=1 ;;
    l|L) refetch_lyrics; force_refresh=1 ;;
    r|R) force_refresh=1 ;;
  esac

  return 0
}

printf "%b%b%b" "$ALT_ON" "$CURSOR_OFF" "$CLEAR"
stty -echo -icanon time 0 min 0 2>/dev/null || true

tick=0
while true; do
  term_size
  clear_on_resize

  if (( force_refresh == 1 || tick % 8 == 0 )); then
    refresh_player
    force_refresh=0
  elif (( has_player == 1 )); then
    refresh_position
  fi

  if (( has_player == 1 )); then
    draw "$tick"
  else
    draw_empty
  fi

  key=""
  IFS= read -r -s -n 1 -t 0.1 key 2>/dev/null || true
  handle_key "$key" || break

  tick=$((tick + 1))
done
